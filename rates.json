# Expected columns (adjust here if GP ever renames them)
COL = {
    "uom":       "UOM",
    "rate":      "RATE",
    "flat":      "FLAT CHARGE",
    "currency":  "CURRENCY CODE",
    "min":       "MINIMUM CHARGE",
    "band_min":  "BAND UOM MIN",
    "band_max":  "BAND UOM MAX",
    "equip":     "EQUIPMENT",
    "orig_loc":  "ORIGIN LOCALITY,ADMINISTRATIVE AREA,COUNTRY",
    "orig_st":   "ORIGIN ADMINISTRATIVE AREA,COUNTRY",
    "orig_co":   "ORIGIN COUNTRY",
    "dest_loc":  "DESTINATION LOCALITY,ADMINISTRATIVE AREA,COUNTRY",
    "dest_st":   "DESTINATION ADMINISTRATIVE AREA,COUNTRY",
    "dest_zip":  "DESTINATION POSTAL CODE,ADMINISTRATIVE AREA,COUNTRY",
    "dest_co":   "DESTINATION COUNTRY",
}

def _read_first_sheet(path: str) -> pd.DataFrame:
    xl = pd.read_excel(path, sheet_name=None)
    sheet_names = list(xl.keys())
    df = xl[sheet_names[0]]
    print(f"Using sheet: {sheet_names[0]!r}")
    return df

def _v(row, key):
    col = COL[key]
    val = row.get(col)
    if val is None or (isinstance(val, float) and pd.isna(val)):
        return None
    return val

def _flt(row, key):
    val = _v(row, key)
    try:
        return float(val) if val is not None else None
    except (ValueError, TypeError):
        return None

def _s(row, key):
    val = _v(row, key)
    return str(val).strip() if val is not None else None

def _convert_one(mode: str, excel_path: str):
    print(f"\nReading {mode}: {excel_path}")
    df = _read_first_sheet(excel_path)
    print(f"  Rows: {len(df)}")

    # sanity: warn if required columns missing
    missing = [COL[k] for k in ["uom","rate","flat","orig_loc","dest_loc","dest_zip"] if COL[k] not in df.columns]
    if missing:
        print(f"⚠️  Warning: Missing expected columns in {mode}:")
        for m in missing:
            print(f"    - {m}")

    rates = []
    for _, row in df.iterrows():
        rates.append([
            mode,                      # 0: MODE  (TRUCK / RAIL)
            _s(row, "uom"),            # 1
            _flt(row, "rate"),         # 2
            _flt(row, "flat"),         # 3
            _s(row, "currency") or "USD",  # 4
            _flt(row, "min") or 0,     # 5
            _flt(row, "band_min"),     # 6
            _flt(row, "band_max"),     # 7
            _s(row, "equip"),          # 8 (kept for future; UI won't use)
            _s(row, "orig_loc"),       # 9
            _s(row, "orig_st"),        # 10
            _s(row, "orig_co"),        # 11
            _s(row, "dest_loc"),       # 12
            _s(row, "dest_st"),        # 13
            _s(row, "dest_zip"),       # 14
            _s(row, "dest_co"),        # 15
        ])
    return rates

def convert(truck_excel: str, rail_excel: str, output_path: str = "rates.json"):
    truck_rates = _convert_one("TRUCK", truck_excel)
    rail_rates  = _convert_one("RAIL",  rail_excel)

    rates_all = truck_rates + rail_rates

    origins = sorted(set(r[9] for r in rates_all if r[9]))
    origin_zips = {o: ORIGIN_ZIPS.get(o, "") for o in origins}

    new_origins = [o for o in origins if o not in ORIGIN_ZIPS]
    if new_origins:
        print(f"\n⚠️  New origin facilities found (no zip on file — add them to ORIGIN_ZIPS):")
        for o in new_origins:
            print(f"     {o}")

    out = {
        "rates": rates_all,                 # each row begins with MODE
        "modes": ["TRUCK", "RAIL"],
        "origins": origins,
        "origin_zips": origin_zips,
        "meta": {
            "truck_source": os.path.basename(truck_excel),
            "rail_source": os.path.basename(rail_excel),
        }
    }

    with open(output_path, "w", encoding="utf-8") as f:
        json.dump(out, f, separators=(",", ":"))

    size_kb = os.path.getsize(output_path) / 1024
    print(f"\n✅  Written: {output_path}")
    print(f"    Total Rates: {len(rates_all):,}")
    print(f"    Truck Rates: {len(truck_rates):,}")
    print(f"    Rail Rates:  {len(rail_rates):,}")
    print(f"    Origins:     {len(origins)}")
    print(f"    File size:   {size_kb:.0f} KB")
    print(f"\nNext step: upload {output_path} to GitHub → drw00d/GP-FET")

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: python convert_to_rates_json.py <truck-excel> <rail-excel>")
        print("Example: python convert_to_rates_json.py 'FR00 Gen 2.xlsx' 'GP Rail Freight.xlsx'")
        sys.exit(1)

    truck_excel = sys.argv[1]
    rail_excel  = sys.argv[2]

    if not os.path.exists(truck_excel):
        print(f"Error: file not found: {truck_excel}")
        sys.exit(1)
    if not os.path.exists(rail_excel):
        print(f"Error: file not found: {rail_excel}")
        sys.exit(1)

    convert(truck_excel, rail_excel)
