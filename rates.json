#!/usr/bin/env python3
"""
convert_to_rates_json.py
─────────────────────────────────────────────────────────────────────────────
Convert TRUCK + RAIL weekly Excel files into a single rates.json for GitHub Pages.

Usage:
    python convert_to_rates_json.py "FR00 Gen 2.xlsx" "GP Rail Freight.xlsx"

Output:
    rates.json (contains both modes)

Requirements:
    pip install pandas openpyxl
─────────────────────────────────────────────────────────────────────────────
"""

